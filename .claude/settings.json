{
  "permissions": {
    "deny": [
      "Read(./.env)"
    ]
  },
  "model": "opusplan",
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "40",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "MAX_THINKING_TOKENS": "10000",
    "CLAUDE CODE_EFFORT_LEVEL": "medium",
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "1",
    "CLAUDE_CODE_NEW_INIT": "1"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f; case \"$f\" in *.py) uv run ruff check --fix --select I \"$f\" ;; esac; } 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}